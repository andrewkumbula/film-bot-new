BOT_TOKEN=your_telegram_bot_token_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=xiaomi/mimo-v2-flash
# Модель для кратких описаний фильмов (ночной бэкфилл); по умолчанию Haiku
# OPENROUTER_MODEL_SHORT_DESC=anthropic/claude-3-5-haiku
# DEBUG=true
# LOG_PATH=./app_data/bot.log   — дублировать логи в файл (удобно смотреть через tail -f)
# DB_PATH=./app_data/bot.db

# Опционально: API Кинопоиска (поиск фильмов, постеры; токен в @poiskkinodev_bot для poiskkino.dev)
# KINOPOISK_API_KEY=your_kinopoisk_api_key
# KINOPOISK_BASE_URL=https://api.poiskkino.dev

# Топ 250: для корректных позиций (без дублей) — неофициальный API (свой ключ):
# KINOPOISK_TOP250_BASE_URL=https://kinopoiskapiunofficial.tech
# KINOPOISK_UNOFFICIAL_API_KEY=ваш_ключ_с_сайта_kinopoiskapiunofficial.tech

# Постеры: сколько показывать в карточке фильма (1 или 3), если API отдал несколько
# SHOW_POSTERS_COUNT=3

# Ежедневный отчёт: лог движений пользователей (flow_log) за сутки в CSV
# REPORT_CHAT_ID=123456789   — ваш Telegram chat_id (узнать: написать @userinfobot)
# REPORT_TIME=09:00          — время отправки (локальное время сервера, формат HH:MM)

# Дозаполнение kinopoisk_id (ночной джоб): поиск «название год кинопоиск» через Tavily, ИИ извлекает точное название из результатов
# TAVILY_API_KEY=tvly-...    — ключ на https://tavily.com (без него уточнение по поиску не выполняется)

